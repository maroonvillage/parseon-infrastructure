# Terraform local files and directories
.terraform/

# Terraform state files (contain sensitive data — remote state is in HCP Terraform)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files (may contain sensitive values)
# Environment tfvars are intentionally tracked (no secrets — secrets go in HCP Terraform workspace variables)
*.tfvars
!environments/*/terraform.tfvars

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform crash logs
crash.log
crash.*.log

# Terraform plan output files
*.tfplan
plan_output.txt

# Terraform generated files
.terraform.tfstate.lock.info

# Terraform provider lock files should be committed for reproducible installs
# (removed .terraform.lock.hcl from exclusions)

# macOS
.DS_Store
*terraform.lock.hcl
*/environments/dev/.terraform.lock.hcl
